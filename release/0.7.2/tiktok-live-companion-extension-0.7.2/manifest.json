{
  "manifest_version": 3,
  "name": "TikTok LIVE Companion",
  "version": "0.7.2",
  "description": "Accessible TikTok LIVE chat speech, participant statistics, captions, player controls and optional paired local audio tools.",
  "minimum_chrome_version": "114",
  "key": "",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "tabCapture",
    "tabs",
    "webRequest",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://www.tiktok.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "*://*.tiktokcdn.com/*",
    "*://*.tiktokcdn-eu.com/*",
    "*://*.tiktokcdn-us.com/*",
    "*://*.tiktokcdn-in.com/*",
    "*://*.ttlivecdn.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TikTok LIVE Companion öffnen"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": ["content-core.js", "content.js"],
      "run_at": "document_start"
    }
  ]
}
