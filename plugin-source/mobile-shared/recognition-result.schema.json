{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiktok-live-companion.invalid/schemas/recognition-result-v1.json",
  "title": "TikTok LIVE Companion Recognition Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["matched", "title", "artist", "source"],
  "properties": {
    "matched": { "type": "boolean" },
    "title": { "type": "string", "maxLength": 512 },
    "artist": { "type": "string", "maxLength": 512 },
    "album": { "type": "string", "maxLength": 512 },
    "artworkUrl": { "type": "string", "format": "uri", "maxLength": 2048 },
    "songUrl": { "type": "string", "format": "uri", "maxLength": 2048 },
    "matchOffset": { "type": "number", "minimum": 0 },
    "source": { "enum": ["microphone", "webview"] }
  }
}
