            }
          ],
          "message": {
            "text": "The MAIN-world hook rejects binary frames larger than 16 MiB before decoding, but `proto-main.js` fully materializes gzip output through `Response.arrayBuffer()` and `hook.js` starts each decode without an in-flight budget. Small compressed inputs can therefore cause disproportionate local memory and CPU work before parser errors are contained."
          },
          "partialFingerprints": {
            "codexSecurity/v1": "codex-security/v1:sha256:b63d175ba778bcad57d17997f9e61fd366bfde7108cf239dc043005d3fe26f85"
