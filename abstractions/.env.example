# =============================================================================
# .env.example — Konfigurationsvorlage für den Abstractions Manager
#
# Kopieren und anpassen:
#   cp .env.example .env
#
# WICHTIG: .env NIEMALS in Git committen!
#          Sicherstellen dass .env in .gitignore steht.
# =============================================================================

# ---------------------------------------------------------------------------
# KI-Provider API-Schlüssel (mind. einer erforderlich)
# ---------------------------------------------------------------------------

# Anthropic Claude API-Schlüssel
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=

# OpenAI API-Schlüssel (optional, als Alternative)
# Format: sk-...
OPENAI_API_KEY=

# OpenRouter API-Schlüssel (wenn openrouter/-Modelle verwendet werden)
# Format: sk-or-v1-...
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Workspace-Konfiguration
# ---------------------------------------------------------------------------

# Absoluter Pfad zum OpenClaw-Workspace
# Standard: /home/openclaw/.openclaw/workspace
OPENCLAW_WORKSPACE=/home/openclaw/.openclaw/workspace

# ---------------------------------------------------------------------------
# Logging-Konfiguration
# ---------------------------------------------------------------------------

# Log-Level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Standard: INFO
ABSTRACTIONS_LOG_LEVEL=INFO

# JSON-Logging: 1 = JSON-Format (Produktion), 0 = Text (Entwicklung)
# Standard: 1
ABSTRACTIONS_JSON_LOGGING=1

# ---------------------------------------------------------------------------
# Abstractions Manager
# ---------------------------------------------------------------------------

# Standard-KI-Modell für Portierungen
# Muss in der Allowlist in validators.py enthalten sein
ABSTRACTIONS_DEFAULT_MODEL=openrouter/anthropic/claude-3-5-sonnet-20241022

# Maximale parallele Portierungs-Worker
# Standard: 4
ABSTRACTIONS_MAX_WORKERS=4

# Cron-Intervall in Stunden (nur für Dokumentation — Cron selbst konfigurieren)
# Standard: 6
ABSTRACTIONS_CRON_INTERVAL_HOURS=6

# Dry-Run-Modus: 1 = keine echten Commits, 0 = normaler Betrieb
# Standard: 0
ABSTRACTIONS_DRY_RUN=0

# ---------------------------------------------------------------------------
# Git-Konfiguration
# ---------------------------------------------------------------------------

# Git-Autor für automatische Commits
GIT_AUTHOR_NAME=Abstractions Manager
GIT_AUTHOR_EMAIL=abstractions@openclaw.local

# GPG-Signing für Commits aktivieren: 1 = ja, 0 = nein
# Standard: 0 (sollte in Produktion auf 1 gesetzt werden)
GIT_SIGN_COMMITS=0

# ---------------------------------------------------------------------------
# Multi-Node-Infrastruktur
# ---------------------------------------------------------------------------

# Node 1 (Gateway-Master)
NODE_1_HOST=localhost
NODE_1_PORT=8001

# Node 2 (Stable Worker)
NODE_2_HOST=
NODE_2_PORT=8002

# Node 5 (Mobile — optional)
NODE_5_HOST=
NODE_5_PORT=8005

# Verbindungs-Timeout zu Nodes in Sekunden
NODE_CONNECTION_TIMEOUT_SECONDS=30
